{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp",
        "--headless",
        "--isolated",
        "--executablePath",
        "/usr/bin/chromium-browser",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-dev-shm-usage",
        "--chromeArg=--disable-gpu",
        "--chromeArg=--disable-software-rasterizer"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-e4a14922-f73d-47ae-b2fc-70fc14984114"
      }
    },
    "postgres": {
      "command": "uvx",
      "args": [
        "postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "postgresql://demo:demo@quarkus-demo-db:5432/DemoDB"
      }
    }
  }
}